# === API ===
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# === PostgreSQL (для Langfuse) ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/langfuse?schema=public

# === Langfuse ===
LANGFUSE_PUBLIC_KEY=pk-lf-your_key
LANGFUSE_SECRET_KEY=sk-lf-your_key
LANGFUSE_SALT=your_strong_salt_min_32_chars
LANGFUSE_ENCRYPTION_KEY=your_32_char_encryption_key!!
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars!!

# === Redis ===
REDIS_PASSWORD=your_redis_password

# === Qdrant ===
QDRANT_API_KEY=your_qdrant_api_key

# === Neo4j ===
NEO4J_PASSWORD=your_neo4j_password
